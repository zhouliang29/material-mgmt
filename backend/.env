# 环境配置文件 - 复制为 .env 使用

# 应用配置
APP_NAME=物料管理系统
APP_VERSION=1.0.0
DEBUG=True

# 数据库配置
DATABASE_URL=sqlite:///./material.db
# PostgreSQL 示例: postgresql://user:password@localhost:5432/material_mgmt

# JWT 配置
SECRET_KEY=change-this-to-a-random-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 跨域配置
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
